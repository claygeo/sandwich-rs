# /etc/sandwich-rs/env — chmod 600, owned by root:sandwich
# Copy this file to /etc/sandwich-rs/env on the VPS and fill in real values.

HELIUS_API_KEY=
SANDWICH_WS_URL=
# Set to "true" only on paid Helius tier (free tier Atlas returns 403)
SANDWICH_USE_ATLAS=

# Pooler URL for writes — use SESSION mode (port 5432) not transaction (6543).
# Sqlx + Supavisor transaction-mode hits "prepared statement sqlx_s_NN already
# exists" errors after a few hundred queries because connections rotate. Session
# mode keeps connections sticky so the prepared-statement cache stays consistent.
SUPABASE_POOLER_URL=postgres://postgres.PROJECT_REF:PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# Direct DB URL fallback (only used if pooler not set)
SUPABASE_DB_URL=

SUPABASE_URL=https://mqlnirjtuiwreohbpeli.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

SANDWICH_HTTP_BIND=127.0.0.1:8080
SANDWICH_STATE_DIR=/var/lib/sandwich-rs
RUST_LOG=sandwich_rs=info,sqlx=warn

# Default watched programs: Raydium V4 + Orca Whirlpool
# Override here to subscribe to additional DEXes (comma-separated program IDs)
WATCHED_PROGRAMS=

# Pyth Hermes SOL/USD poller (default on; set "off" to disable)
SANDWICH_PYTH=
