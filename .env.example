# sandwich-rs backend env
# Copy to .env (gitignored) and fill in.

# --- Solana / Helius ---
# Free tier: https://dashboard.helius.dev (100k credits/day, transactionSubscribe enhanced WS)
HELIUS_API_KEY=

# Override the WS endpoint (default = Helius if HELIUS_API_KEY set, else public mainnet)
SANDWICH_WS_URL=

# --- Supabase ---
# Direct Postgres URL (read-write via service role; never commit)
# Format: postgres://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres
SUPABASE_DB_URL=

# Pooler URL (preferred for write hot path — transaction mode, port 6543)
# Format: postgres://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
SUPABASE_POOLER_URL=

# Public REST URL (for healthchecks if PostgREST is ever used as fallback)
SUPABASE_URL=https://mqlnirjtuiwreohbpeli.supabase.co

# Anon key (public, also used by frontend)
SUPABASE_ANON_KEY=

# Service role key (server-only — never ship to frontend)
SUPABASE_SERVICE_ROLE_KEY=

# --- Telegram (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Logging ---
RUST_LOG=sandwich_rs=info,sqlx=warn
